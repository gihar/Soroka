# Telegram Bot Token
TELEGRAM_TOKEN=your_telegram_bot_token_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Лёгкие модели для вспомогательных LLM-шагов (сопоставление спикеров, ЭТАП 1 анализа).
# Отдельно от модели генерации протокола. Значение — ID модели у активного провайдера
# (для OpenRouter — с префиксом, например openai/gpt-5-nano).
SPEAKER_MAPPING_MODEL=openai/gpt-5-nano
ANALYSIS_STAGE_MODEL=openai/gpt-5-nano

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Yandex GPT API Key and Folder ID
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_yandex_folder_id_here

# LLM timeout (seconds)
LLM_TIMEOUT_SECONDS=30

# Database URL (по умолчанию SQLite)
DATABASE_URL=sqlite:///bot.db

# Максимальный размер файла (в байтах)
MAX_FILE_SIZE=52428800

# Директория для временных файлов
TEMP_DIR=temp

# Уровень логирования
LOG_LEVEL=INFO
